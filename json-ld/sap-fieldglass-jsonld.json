  "@graph": [
    {
      "@id": "fieldglass:WorkOrder",
      "@type": "rdfs:Class",
      "rdfs:label": "Work Order",
      "rdfs:comment": "A document defining engagement terms for a contingent worker in SAP Fieldglass",
      "rdfs:subClassOf": "schema:Order"
    },
    {
      "@id": "fieldglass:StatementOfWork",
      "@type": "rdfs:Class",
      "rdfs:label": "Statement of Work",
      "rdfs:comment": "A formal document capturing work activities, deliverables, and timeline for service engagements",
      "rdfs:subClassOf": "schema:Service"
    },
    {
      "@id": "fieldglass:ContingentWorker",
      "@type": "rdfs:Class",
      "rdfs:label": "Contingent Worker",
      "rdfs:comment": "An external worker engaged through SAP Fieldglass who is not a full-time employee",
      "rdfs:subClassOf": "schema:Person"
    },
    {
      "@id": "fieldglass:WorkItem",
      "@type": "rdfs:Class",
      "rdfs:label": "Work Item",
      "rdfs:comment": "A business document in SAP Fieldglass requiring approval action",
      "rdfs:subClassOf": "schema:Action"
    },
    {
      "@id": "fieldglass:AuditTrail",
      "@type": "rdfs:Class",
      "rdfs:label": "Audit Trail",
      "rdfs:comment": "Chronological record of changes and actions in SAP Fieldglass",
      "rdfs:subClassOf": "schema:Event"
    }
  ]
}